# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── Firebase Admin SDK ────────────────────────────────────
# Base64-encode your Firebase service account JSON:
# Mac/Linux: base64 -i serviceAccount.json
# Windows: [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccount.json")) | Set-Clipboard
FIREBASE_SERVICE_ACCOUNT_BASE64=<base64_encoded_service_account_json>
FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── Python AI Microservice ────────────────────────────────
# URL of running Python Flask microservice (local or remote)
PYTHON_AI_URL=http://localhost:10000
# Internal secret shared between Node and Python to prevent unauthorized access
INTERNAL_API_SECRET=change_this_to_a_random_secret_string

# ─── Gemini AI (used by Python microservice, but here for reference) ───
GEMINI_API_KEY=AIzaSy...

# ─── Razorpay ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Stripe (fallback) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated allowed origins
FRONTEND_URL=http://localhost:5173
